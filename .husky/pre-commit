#!/bin/sh
# Pre-commit: blocks commits that break TypeScript or unit tests.

echo "🔍 Type checking..."
npm run typecheck || { echo "❌ TypeScript errors. Fix before committing."; exit 1; }

echo "🧪 Unit tests..."
npm test || { echo "❌ Unit tests failed. Fix before committing."; exit 1; }

echo "✅ Pre-commit checks passed."
